{
  "name": "karis-monorepo",
  "private": true,
  "description": "The open-source CMO for AI agents",
  "workspaces": [
    "cli"
  ],
  "scripts": {
    "build": "npm run build --workspace=cli",
    "build:staging": "npm run build:staging --workspace=cli",
    "dev": "npm run dev --workspace=cli",
    "typecheck": "npm run typecheck --workspace=cli",
    "karis": "node ./cli/bin/karis.js",
    "karis:staging": "node ./cli/bin/karis-staging.js",
    "generate": "python3 scripts/generate_marketplace.py && python3 scripts/generate_agents.py"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/karis-ai/karis.git"
  },
  "keywords": [
    "geo",
    "seo",
    "ai-search",
    "marketing",
    "cmo",
    "agent-skills",
    "brand-intelligence"
  ]
}
